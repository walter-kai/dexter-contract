{
  "name": "dexter-contract-server",
  "version": "1.0.0",
  "description": "Uniswap v4 hooks for swap tracking and analytics",
  "scripts": {
    "anvil": "source .env && anvil --fork-url $MAINNET_RPC_URL --chain-id 1",
    "test": "forge test",
    "test:verbose": "forge test -vvv",
    "build": "forge build",
    "remap": "forge remappings > remappings.txt",
    
    "deploy:core:anvil": "source .env && forge script script/DeployCore.s.sol:DeployCore --rpc-url http://localhost:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 --skip-simulation",
    "deploy:core:main": "./deploy/deploy-with-ledger.sh script/DeployCore.s.sol mainnet",
    "deploy:core:sepolia": "source .env && forge script script/DeployCore.s.sol:DeployCore --rpc-url $SEPOLIA_RPC_URL --broadcast --private-key $PRIVATE_KEY --verify --etherscan-api-key $ETHERSCAN_API_KEY",
    
    "deploy:tools:anvil": "source .env && forge script script/DeployTools.s.sol:DeployTools --rpc-url http://localhost:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 --skip-simulation",
    "deploy:tools:main": "./deploy/deploy-with-ledger.sh script/DeployTools.s.sol mainnet", 
    "deploy:tools:sepolia": "source .env && forge script script/DeployTools.s.sol:DeployTools --rpc-url $SEPOLIA_RPC_URL --broadcast --private-key $PRIVATE_KEY --verify --etherscan-api-key $ETHERSCAN_API_KEY",
    
    "deploy:both:anvil": "source .env && forge script script/DeployUnified.s.sol:DeployUnified --rpc-url http://localhost:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 --skip-simulation",
    "deploy:both:main": "./deploy/deploy-with-ledger.sh script/DeployUnified.s.sol mainnet",
    "deploy:both:sepolia": "source .env && forge script script/DeployUnified.s.sol:DeployUnified --rpc-url $SEPOLIA_RPC_URL --broadcast --private-key $PRIVATE_KEY --verify --etherscan-api-key $ETHERSCAN_API_KEY",
    
    "deploy:ledger": "./deploy/deploy-with-ledger.sh"
  },
  "keywords": [
    "uniswap",
    "v4",
    "hooks",
    "defi",
    "swap",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.0.1",
    "ethers": "^6.15.0",
    "ts-node": "^10.9.2"
  }
}
