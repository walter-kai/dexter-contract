{
  "name": "dexter-contract-server",
  "version": "1.0.0",
  "description": "Uniswap v4 hooks for swap tracking and analytics",
  "scripts": {
    "anvil": "source .env && anvil --fork-url $MAINNET_RPC_URL --chain-id 1",
    "anvil:setup": "node setup/anvil-setup.js",
    "anvil:contract": "node setup/deploy-with-ledger.js script/DeployCore.s.sol:DeployCore anvil",
    "test": "forge test",
    "test:verbose": "forge test -vvv",
    "build": "forge build",
    "remap": "forge remappings > remappings.txt",
    
    "main:contract": "node setup/deploy-with-ledger.js script/DeployCore.s.sol:DeployCore mainnet",
    "main:pool": "node setup/create-single-pool.js mainnet",
    
    "deploy:pool:mainnet": "node setup/deploy-with-ledger.js script/InitializePool.s.sol:InitializePool mainnet && node setup/sync-pools-to-firebase.js mainnet",
    "deploy:pool:anvil": "node setup/deploy-with-ledger.js script/DeploySimple.s.sol:DeploySimple anvil && node setup/deploy-with-ledger.js script/InitializePool.s.sol:InitializePool anvil && node setup/sync-pools-to-firebase.js anvil",
    
    "deploy:core:anvil": "source .env && forge script script/DeployCore.s.sol:DeployCore --rpc-url http://localhost:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 --skip-simulation",
    "deploy:core:sepolia": "source .env && forge script script/DeployCore.s.sol:DeployCore --rpc-url $SEPOLIA_RPC_URL --broadcast --private-key $PRIVATE_KEY --verify --etherscan-api-key $ETHERSCAN_API_KEY",
    
    "deploy:ledger": "node setup/deploy-with-ledger.js"
  },
  "keywords": [
    "uniswap",
    "v4",
    "hooks",
    "defi",
    "swap",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.0.1",
    "ethers": "^6.15.0",
    "firebase-admin": "^13.4.0",
    "ts-node": "^10.9.2"
  }
}
