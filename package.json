{
  "name": "dexter-contract-server",
  "version": "1.0.0",
  "description": "Uniswap v4 hooks for swap tracking and analytics",
  "scripts": {
    "anvil": "source .env && anvil --fork-url $MAINNET_RPC_URL --chain-id 1",
    "test": "forge test",
    "test:verbose": "forge test -vvv",
    "build": "forge build",
    "remap": "forge remappings > remappings.txt",
    "deploy:swap:main": "./deploy/deploy-with-ledger.sh script/DeploySwapToken.s.sol mainnet",
    "deploy:swap:anvil": "./deploy/deploy-with-ledger.sh script/DeploySwapToken.s.sol anvil",
    "deploy:batch:anvil": "source .env && forge script script/DeployBatch.s.sol:DeployBatch --rpc-url http://localhost:8545 --broadcast --private-key 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 --skip-simulation",
    "deploy:batch:main": "./deploy/deploy-with-ledger.sh script/DeployBatch.s.sol mainnet",
    "deploy:ledger": "./deploy/deploy-with-ledger.sh"
  },
  "keywords": [
    "uniswap",
    "v4",
    "hooks",
    "defi",
    "swap",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.0.1",
    "ethers": "^6.15.0",
    "ts-node": "^10.9.2"
  }
}
