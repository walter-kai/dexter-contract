# RPC URLs - Replace with your actual API keys
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Fee recipient address
FEE_RECIPIENT_ADDRESS=0xYOUR_FEE_RECIPIENT_ADDRESS

# NOTE: Private keys are no longer needed in environment files!
# - For Anvil: Use default unlocked accounts or retrieve dynamically
# - For Mainnet: Use Ledger hardware wallet for security
# WARNING: NEVER commit actual API keys to Git!
